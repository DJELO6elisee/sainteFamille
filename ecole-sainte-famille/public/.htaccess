# Configuration pour forcer la mise à jour du cache PWA
# La Petite Académie - Version 1.3.0

# Désactiver le cache pour les fichiers HTML
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Désactiver le cache pour les fichiers JavaScript et CSS
<FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Désactiver le cache pour le service worker
<FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Désactiver le cache pour le manifest
<FilesMatch "manifest\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Désactiver le cache pour le fichier de version
<FilesMatch "version\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Cache long pour les images (1 an)
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Cache moyen pour les polices (1 mois)
<FilesMatch "\.(woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# Redirection pour forcer le rechargement
RewriteEngine On

# Ajouter un paramètre de version à l'URL si pas présent
RewriteCond %{QUERY_STRING} !v=
RewriteRule ^(.*)$ $1?v=1.3.0.20250115 [QSA,L]

# Redirection pour clear-cache
RewriteRule ^clear-cache$ /clear-cache.html [L]

# Compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Headers de sécurité
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Version de l'application
Header set X-App-Version "1.3.0.20250115"
