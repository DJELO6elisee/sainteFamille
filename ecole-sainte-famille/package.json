    "proxy": "http://localhost:5000",
    "dependencies": {
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@mui/icons-material": "^5.0.0",
        "@mui/material": "^5.15.10",
        "@mui/x-date-pickers": "^6.19.4",
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/react": "^13.4.0",
        "@testing-library/user-event": "^13.5.0",
        "@types/jest": "^27.5.2",
        "@types/node": "^16.18.80",
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@types/socket.io-client": "^1.4.36",
        "axios": "^1.6.7",
        "date-fns": "^2.30.0",
        "html2canvas": "^1.4.1",
        "html2pdf.js": "^0.10.3",
        "jspdf": "^3.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-helmet-async": "^2.0.5",
        "react-router-dom": "^6.22.0",
        "react-scripts": "5.0.1",
        "react-slick": "^0.30.3",
        "react-to-print": "^3.1.1",
        "slick-carousel": "^1.8.1",
        "socket.io-client": "^4.8.1",
        "typescript": "^4.9.5",
        "web-vitals": "^2.1.4",
        "xlsx": "^0.18.5"
    },
    "scripts": {
        "start": "react-scripts start",
        "start-https": "set HTTPS=true&&set SSL_CRT_FILE=cert.pem&&set SSL_KEY_FILE=key.pem&&react-scripts start",
        "build": "node scripts/update-version.js && react-scripts build",
        "build-clean": "node scripts/clear-cache.js && node scripts/update-version.js && react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "generate-icons": "node generate-real-icons.js",
        "update-icons": "node update-all-icons.js",
        "generate-pwa-icons": "node scripts/generate-pwa-icons.js",
        "pwa-setup": "npm run generate-icons && npm run update-icons && npm run build",
        "clear-cache": "node scripts/clear-cache.js",
        "force-update": "node scripts/clear-cache.js && npm run build",
        "clear-safari-cache": "node scripts/clear-safari-cache.js",
        "fix-safari": "node scripts/clear-safari-cache.js && npm run build",
        "pwa-force-update": "node scripts/force-pwa-update.js",
        "deploy": "node scripts/update-version.js && npm run pwa-force-update"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@types/react-slick": "^0.23.13",
        "http-server": "^14.1.1",
        "sharp": "^0.34.4"
    }
}